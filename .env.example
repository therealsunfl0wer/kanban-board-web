# Server
NODE_ENV=production
JWT_SECRET=change-me
PORT=3000
HOST=0.0.0.0
# Absolute path to client/dist when serving the SPA from the server
CLIENT_DIST_DIR=/absolute/path/to/client/dist
# Comma-separated list of allowed origins
CORS_ORIGINS=https://your-app.example
# Set true to allow all origins (not recommended in production)
CORS_ALLOW_ALL=false

# Client (Vite)
# API base URL for separate client hosting
VITE_API_BASE_URL=https://api.your-app.example
